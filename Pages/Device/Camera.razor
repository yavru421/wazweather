@page "/device/camera"
@inject IJSRuntime JSRuntime
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Camera API - GlassWASM</PageTitle>

<PageHeader Title="Camera & Capture" 
            Description="Access the device's front or rear camera feeds to stream real-time video, capture high-res snapshots, and download them." 
            ApiSupported="_isSupported" />

<div class="page-container">
    <PermissionGate @ref="_gate" 
                    IsSupported="_isSupported" 
                    PermissionName="camera" 
                    PermissionLabel="Camera"
                    Description="This page requires access to your camera to display the live feed and capture photos."
                    RequestPermission="StartCameraFeedAsync">
        
        <div class="camera-demo-grid">
            <!-- Left Side: Live Feed -->
            <DemoCard Title="Live Camera Stream">
                <div class="video-container">
                    <video id="camera-stream" autoplay playsinline></video>
                    @if (_isStreaming)
                    {
                        <span class="stream-badge animate-pulse">LIVE</span>
                    }
                    else
                    {
                        <div class="video-placeholder">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                            <p>Camera feed stopped</p>
                        </div>
                    }
                </div>

                <div class="camera-controls">
                    <button class="btn-control" @onclick="ToggleCameraDirection" disabled="@(!_isStreaming)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
                        Switch to @(_frontCamera ? "Rear" : "Front")
                    </button>

                    <button class="btn-control btn-danger" @onclick="StopCameraFeedAsync" disabled="@(!_isStreaming)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
                        Stop Stream
                    </button>

                    <button class="btn-control btn-success" @onclick="StartCameraFeedAsync" disabled="@(_isStreaming)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                        Start Stream
                    </button>
                </div>
            </DemoCard>

            <!-- Right Side: Capture Snapshots -->
            <DemoCard Title="Captured Snapshot">
                <div class="photo-container">
                    @if (!string.IsNullOrEmpty(_capturedPhotoData))
                    {
                        <img src="@_capturedPhotoData" alt="Captured snapshot" class="captured-img" />
                    }
                    else
                    {
                        <div class="photo-placeholder">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                            <p>No snapshot captured yet</p>
                        </div>
                    }
                </div>

                <div class="camera-controls">
                    <button class="btn-primary" @onclick="CapturePhotoAsync" disabled="@(!_isStreaming)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle></svg>
                        Capture Snapshot
                    </button>

                    <a class="btn-control @(string.IsNullOrEmpty(_capturedPhotoData) ? "disabled" : "")" 
                       href="@_capturedPhotoData" 
                       download="glasswasm-snapshot.jpg"
                       title="Download Photo">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        Download
                    </a>
                </div>
            </DemoCard>
        </div>
    </PermissionGate>
</div>

@code {
    private PermissionGate? _gate;
    private bool _isSupported = true;
    private bool _isStreaming = false;
    private bool _frontCamera = true;
    private string? _capturedPhotoData;
    private IJSObjectReference? _cameraModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Simple camera support detection
            try
            {
                var capsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var caps = await capsModule.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                _isSupported = caps.ContainsKey("camera") && caps["camera"];
                StateHasChanged();
            }
            catch
            {
                _isSupported = false;
                StateHasChanged();
            }
        }
    }

    private async Task StartCameraFeedAsync()
    {
        try
        {
            _cameraModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/camera.module.js");
            _gate?.ForceStatus("granted");
            StateHasChanged();
            await Task.Delay(50);

            var result = await _cameraModule.InvokeAsync<bool>("startCamera", "camera-stream", _frontCamera);
            if (result)
            {
                _isStreaming = true;
                ToastService.Success("Camera stream started successfully.");
            }
        }
        catch (Exception ex)
        {
            _isStreaming = false;
            ToastService.Error("Failed to access camera: " + ex.Message);
            _gate?.ForceStatus("denied");
        }
        StateHasChanged();
    }

    private async Task StopCameraFeedAsync()
    {
        if (_cameraModule != null)
        {
            try
            {
                await _cameraModule.InvokeVoidAsync("stopCamera", "camera-stream");
                _isStreaming = false;
                ToastService.Info("Camera stream stopped.");
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error stopping camera: " + ex.Message);
            }
        }
        StateHasChanged();
    }

    private async Task ToggleCameraDirection()
    {
        _frontCamera = !_frontCamera;
        if (_isStreaming)
        {
            await StartCameraFeedAsync(); // Re-initialize stream with new constraints
        }
    }

    private async Task CapturePhotoAsync()
    {
        if (_cameraModule != null && _isStreaming)
        {
            try
            {
                _capturedPhotoData = await _cameraModule.InvokeAsync<string>("capturePhoto", "camera-stream");
                ToastService.Success("Snapshot captured!");
            }
            catch (Exception ex)
            {
                ToastService.Error("Failed to capture snapshot: " + ex.Message);
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_isStreaming && _cameraModule != null)
        {
            try
            {
                await _cameraModule.InvokeVoidAsync("stopCamera", "camera-stream");
            }
            catch
            {
                // Ignore errors during dispose
            }
        }
        if (_cameraModule != null)
        {
            await _cameraModule.DisposeAsync();
        }
    }
}
