@page "/device/media"
@inject IJSRuntime JSRuntime
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Audio Media API - GlassWASM</PageTitle>

<PageHeader Title="Microphone Level Meter" 
            Description="Utilize Web Audio Context and Analyser Nodes to inspect microphone input frequency bands mapped directly onto a Canvas element." 
            ApiSupported="_isSupported" />

<div class="page-container">
    <PermissionGate @ref="_gate" 
                    IsSupported="_isSupported" 
                    PermissionName="microphone" 
                    PermissionLabel="Microphone"
                    Description="This page requires access to your microphone to analyze the input frequencies and render the volume meter."
                    RequestPermission="StartAudioStreamAsync">
        
        <div class="media-layout">
            <!-- Left Panel: Live Canvas Visualization -->
            <div class="media-main">
                <DemoCard Title="Frequency Visualizer">
                    <div class="canvas-container">
                        <canvas id="mic-canvas" width="600" height="260"></canvas>
                        @if (!_isListening)
                        {
                            <div class="canvas-overlay">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
                                <p>Microphone stream inactive</p>
                            </div>
                        }
                    </div>

                    <div class="media-controls">
                        @if (!_isListening)
                        {
                            <button class="btn-primary" @onclick="StartAudioStreamAsync">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                                Start Microphone
                            </button>
                        }
                        else
                        {
                            <button class="btn-control btn-danger" @onclick="StopAudioStreamAsync">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
                                Stop Microphone
                            </button>
                        }
                    </div>
                </DemoCard>
            </div>

            <!-- Right Panel: Volume Gauges -->
            <div class="media-sidebar">
                <DemoCard Title="Decibel Metrics">
                    <div class="metrics-panel">
                        <div class="volume-meter-container">
                            <span class="meter-label">Average Amplitude</span>
                            <div class="volume-bar-track">
                                <div class="volume-bar-fill" style="width: @VolumePercentage%; background: @MeterFillColor;"></div>
                            </div>
                            <span class="volume-text">@VolumePercentage.ToString("F0")% (@_volumeLevel.ToString("F0") / 255)</span>
                        </div>

                        <div class="radial-gauge-container">
                            <svg class="radial-svg" viewBox="0 0 120 120">
                                <circle class="radial-bg" cx="60" cy="60" r="50"></circle>
                                <circle class="radial-fill" cx="60" cy="60" r="50" 
                                        style="stroke-dashoffset: @RadialOffset; stroke: @MeterFillColor;"></circle>
                            </svg>
                            <div class="radial-text">
                                <span class="radial-value">@VolumePercentage.ToString("F0")</span>
                                <span class="radial-label">DB</span>
                            </div>
                        </div>
                    </div>
                </DemoCard>
            </div>
        </div>
    </PermissionGate>
</div>

@code {
    private PermissionGate? _gate;
    private bool _isSupported = true;
    private bool _isListening = false;
    private IJSObjectReference? _mediaModule;
    private DotNetObjectReference<Media>? _selfReference;

    // Volume monitoring
    private double _volumeLevel = 0; // Ranges 0 - 255

    private double VolumePercentage => Math.Clamp((_volumeLevel / 255.0) * 100, 0, 100);
    private double RadialOffset => 314 - (314 * VolumePercentage / 100); // 2 * pi * r (314.15)

    private string MeterFillColor
    {
        get
        {
            if (VolumePercentage < 50) return "#2ed573";
            if (VolumePercentage < 80) return "var(--safety)";
            return "var(--danger)";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var capsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var caps = await capsModule.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                _isSupported = caps.ContainsKey("media") && caps["media"];
                StateHasChanged();
            }
            catch
            {
                _isSupported = false;
                StateHasChanged();
            }
        }
    }

    private async Task StartAudioStreamAsync()
    {
        try
        {
            _mediaModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/media.module.js");
            _selfReference = DotNetObjectReference.Create(this);
            _gate?.ForceStatus("granted");
            StateHasChanged();
            await Task.Delay(50);

            var result = await _mediaModule.InvokeAsync<bool>("startMic", "mic-canvas", _selfReference, nameof(UpdateVolumeCallback));
            if (result)
            {
                _isListening = true;
                ToastService.Success("Microphone active.");
            }
            else
            {
                _isListening = false;
                ToastService.Error("Failed to access microphone.");
                _gate?.ForceStatus("denied");
            }
        }
        catch (Exception ex)
        {
            _isListening = false;
            ToastService.Error("Audio stream initiation failed: " + ex.Message);
            _gate?.ForceStatus("denied");
        }
        StateHasChanged();
    }

    private async Task StopAudioStreamAsync()
    {
        if (_mediaModule != null)
        {
            try
            {
                await _mediaModule.InvokeVoidAsync("stopMic");
                _isListening = false;
                _volumeLevel = 0;
                ToastService.Info("Microphone deactivated.");
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error deactivating mic: " + ex.Message);
            }
        }
        StateHasChanged();
    }

    [JSInvokable]
    public void UpdateVolumeCallback(double volume)
    {
        _volumeLevel = volume;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_isListening && _mediaModule != null)
        {
            try
            {
                await _mediaModule.InvokeVoidAsync("stopMic");
            }
            catch
            {
                // Ignore dispose errors
            }
        }
        _selfReference?.Dispose();
        if (_mediaModule != null)
        {
            await _mediaModule.DisposeAsync();
        }
    }
}
