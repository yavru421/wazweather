    protected override void OnInitialized()
    {
        for (int i = 0; i < 4; i++)
        {
            _presets[i] = CloneState(_state);
        }
        
        // Populate default values of preset 0
        _state.VibeIndex = 0;
        _state.Tempo = _vibes[0].Tempo;
        _state.KickComplexity = _vibes[0].KickDefault;
        _state.SnareComplexity = _vibes[0].SnareDefault;
        _state.HatComplexity = _vibes[0].HatDefault;
        _state.BassComplexity = _vibes[0].BassDefault;
        _state.MelodyComplexity = _vibes[0].MelodyDefault;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create<object>(this);
            await StudioService.InitStudioAsync(_selfRef, nameof(OnPlayheadTick), nameof(OnGridUpdated));
            await UpdateAudioEngineState();
        }
    }

    private StudioAudioState CloneState(StudioAudioState src)
    {
        return new StudioAudioState
        {
            VibeIndex = src.VibeIndex,
            Tempo = src.Tempo,
            KickComplexity = src.KickComplexity,
            SnareComplexity = src.SnareComplexity,
            HatComplexity = src.HatComplexity,
            BassComplexity = src.BassComplexity,
            MelodyComplexity = src.MelodyComplexity,
            IsPlaying = src.IsPlaying
        };
    }

    private void CopyStateParams(StudioAudioState src, StudioAudioState dst)
    {
        dst.VibeIndex = src.VibeIndex;
        dst.Tempo = src.Tempo;
        dst.KickComplexity = src.KickComplexity;
        dst.SnareComplexity = src.SnareComplexity;
        dst.HatComplexity = src.HatComplexity;
        dst.BassComplexity = src.BassComplexity;
        dst.MelodyComplexity = src.MelodyComplexity;
    }

    // ── Vibe Select Event ───────────────────────────────────────────
    private async Task OnVibeChanged(int newVibeIdx)
    {
        _state.VibeIndex = newVibeIdx;
        var vibe = _vibes[newVibeIdx];
        _state.Tempo = vibe.Tempo;
        
        // Jumps right knobs to their starting default positions
        _state.KickComplexity = vibe.KickDefault;
        _state.SnareComplexity = vibe.SnareDefault;
        _state.HatComplexity = vibe.HatDefault;
        _state.BassComplexity = vibe.BassDefault;
        _state.MelodyComplexity = vibe.MelodyDefault;
        
        await UpdateAudioEngineState();
    }

    // ── Preset Recall & Save ────────────────────────────────────────
    private void HandlePresetPointerDown(PointerEventArgs e, int presetIdx)
    {
        _presetPointerDownTime = DateTime.Now;
    }

    private async Task HandlePresetPointerUp(PointerEventArgs e, int presetIdx)
    {
        var duration = DateTime.Now - _presetPointerDownTime;
        if (duration.TotalSeconds > 1.0)
        {
            _presets[presetIdx] = CloneState(_state);
            _activePreset = presetIdx;
            ToastService.Success($"Saved to Channel {(char)('A' + presetIdx)}");
        }
        else
        {
            CopyStateParams(_presets[presetIdx], _state);
            _activePreset = presetIdx;
            ToastService.Success($"Recalled Channel {(char)('A' + presetIdx)}");
            await UpdateAudioEngineState();
        }
    }

    // ── Knob Drag Logic ─────────────────────────────────────────────
    private void StartKnobDrag(PointerEventArgs e, string knob)
    {
        _draggingKnob = knob;
        _dragStartY = e.ClientY;
        _dragStartVal = knob switch
        {
            "VibeIndex" => _state.VibeIndex / 49.0,
            "Kick" => _state.KickComplexity,
            "Snare" => _state.SnareComplexity,
            "Hat" => _state.HatComplexity,
            "Bass" => _state.BassComplexity,
            "Melody" => _state.MelodyComplexity,
            _ => 0.5
        };
    }
    
    private void OnPointerMove(PointerEventArgs e)
    {
        if (_draggingKnob != null)
        {
            double deltaY = _dragStartY - e.ClientY;
            double newVal = _dragStartVal + (deltaY / 150.0);
            if (newVal < 0) newVal = 0;
            if (newVal > 1) newVal = 1;

            if (_draggingKnob == "VibeIndex")
            {
                int index = (int)Math.Round(newVal * 49);
                if (index != _state.VibeIndex)
                {
                    _ = OnVibeChanged(index);
                }
            }
            else
            {
                switch (_draggingKnob)
                {
                    case "Kick": _state.KickComplexity = newVal; break;
                    case "Snare": _state.SnareComplexity = newVal; break;
                    case "Hat": _state.HatComplexity = newVal; break;
                    case "Bass": _state.BassComplexity = newVal; break;
                    case "Melody": _state.MelodyComplexity = newVal; break;
                }
            }
        }
    }
    
    private async Task OnPointerUp(PointerEventArgs e)
    {
        if (_draggingKnob != null)
        {
            _draggingKnob = null;
            await UpdateAudioEngineState();
        }
    }

    // ── Tap Tempo Logic ─────────────────────────────────────────────
    private async Task HandleTapTempo()
    {
        _tapFlash = true;
        _ = Task.Delay(100).ContinueWith(_ => { _tapFlash = false; InvokeAsync(StateHasChanged); });

        var now = DateTime.Now;
        if (_lastTapTime != DateTime.MinValue)
        {
            var deltaMs = (now - _lastTapTime).TotalMilliseconds;
            if (deltaMs > 2000) 
            {
                _tapCount = 0;
                _tapSumMs = 0;
            }
            else
            {
                _tapSumMs += deltaMs;
                _tapCount++;
                if (_tapCount >= 3)
                {
                    double avgMs = _tapSumMs / _tapCount;
                    _state.Tempo = (int)Math.Round(60000.0 / avgMs);
                    if (_state.Tempo < 60) _state.Tempo = 60;
                    if (_state.Tempo > 240) _state.Tempo = 240;
                    await UpdateAudioEngineState();
                }
            }
        }
        _lastTapTime = now;
    }

    private async Task StartSequencerAsync()
    {
        _isPlaying = true;
        await StudioService.StartPlayAsync(_state);
    }

    private async Task StopSequencerAsync()
    {
        _isPlaying = false;
        await StudioService.StopPlayAsync();
        _currentStep = 0;
    }

    private async Task UpdateAudioEngineState()
    {
        await StudioService.UpdateStateAsync(_state);
    }

    [JSInvokable]
    public void OnPlayheadTick(int step)
    {
        _currentStep = step;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnGridUpdated(bool[][] newGrid, double[] newMelody)
    {
        _currentGrid = newGrid;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_isPlaying)
        {
            await StudioService.StopPlayAsync();
        }
        _selfRef?.Dispose();
    }
}
