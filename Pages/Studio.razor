@page "/"
@inject IStudioService StudioService
@inject IToastService ToastService
@implements IAsyncDisposable
@using BlazorPwaTemplate.Models

<PageTitle>AmpliLoop Beat Studio — Algorithmic Rap Beatmaker</PageTitle>

<div class="studio-page" @onpointermove="OnPointerMove" @onpointerup="OnPointerUp" @onpointerleave="OnPointerUp">
    <!-- ── Hardware Amp Head ───────────────────────── -->
    <div class="amp-head">
        <!-- Left Side: Vibe Select Dial & LCD Screen -->
        <div class="amp-section left-control-panel">
            <div class="knob-container">
                <div class="knob-dial vibe-dial" 
                     @onpointerdown='e => StartKnobDrag(e, "VibeIndex")'
                     style="transform: rotate(@((_state.VibeIndex / 49.0) * 300 - 150)deg)">
                    <div class="knob-indicator"></div>
                </div>
                <span class="knob-label">VIBE SELECT</span>
            </div>

            <!-- Glowing LCD Screen -->
            <div class="lcd-screen">
                <div class="lcd-header">
                    <span class="lcd-index">@((_state.VibeIndex + 1).ToString("D2"))</span>
                    <span class="lcd-name">@_vibes[_state.VibeIndex].Name.ToUpper()</span>
                </div>
                <div class="lcd-meta">
                    <span>STYLE: @_vibes[_state.VibeIndex].Style.ToUpper()</span>
                    <span>TEMPO: @(_state.Tempo.ToString("F0")) BPM</span>
                </div>
                <div class="lcd-body">
                    @_vibes[_state.VibeIndex].Description
                </div>
            </div>
        </div>

        <!-- Center: Right Knobs (5 Complexities) -->
        <div class="amp-section amp-controls">
            <div class="knob-container">
                <div class="knob-dial" @onpointerdown='e => StartKnobDrag(e, "Kick")' style="transform: rotate(@((_state.KickComplexity * 300) - 150)deg)">
                    <div class="knob-indicator"></div>
                </div>
                <span class="knob-label">KICK</span>
                <span class="knob-value">@((_state.KickComplexity * 100).ToString("F0"))%</span>
            </div>

            <div class="knob-container">
                <div class="knob-dial" @onpointerdown='e => StartKnobDrag(e, "Snare")' style="transform: rotate(@((_state.SnareComplexity * 300) - 150)deg)">
                    <div class="knob-indicator"></div>
                </div>
                <span class="knob-label">SNARE</span>
                <span class="knob-value">@((_state.SnareComplexity * 100).ToString("F0"))%</span>
            </div>

            <div class="knob-container">
                <div class="knob-dial" @onpointerdown='e => StartKnobDrag(e, "Hat")' style="transform: rotate(@((_state.HatComplexity * 300) - 150)deg)">
                    <div class="knob-indicator"></div>
                </div>
                <span class="knob-label">HI-HAT</span>
                <span class="knob-value">@((_state.HatComplexity * 100).ToString("F0"))%</span>
            </div>

            <div class="knob-container">
                <div class="knob-dial" @onpointerdown='e => StartKnobDrag(e, "Bass")' style="transform: rotate(@((_state.BassComplexity * 300) - 150)deg)">
                    <div class="knob-indicator"></div>
                </div>
                <span class="knob-label">BASS</span>
                <span class="knob-value">@((_state.BassComplexity * 100).ToString("F0"))%</span>
            </div>

            <div class="knob-container">
                <div class="knob-dial" @onpointerdown='e => StartKnobDrag(e, "Melody")' style="transform: rotate(@((_state.MelodyComplexity * 300) - 150)deg)">
                    <div class="knob-indicator"></div>
                </div>
                <span class="knob-label">MELODY</span>
                <span class="knob-value">@((_state.MelodyComplexity * 100).ToString("F0"))%</span>
            </div>
        </div>

        <!-- Right Side: Channel Presets & Transport -->
        <div class="amp-section amp-system">
            <div class="preset-group">
                <div class="preset-label">CHANNEL</div>
                <div class="preset-buttons">
                    @for (int i = 0; i < 4; i++)
                    {
                        int presetIdx = i;
                        string presetLetter = ((char)('A' + i)).ToString();
                        <button class="btn-preset @(_activePreset == presetIdx ? "active" : "")"
                                @onpointerdown="e => HandlePresetPointerDown(e, presetIdx)"
                                @onpointerup="e => HandlePresetPointerUp(e, presetIdx)">
                            @presetLetter
                        </button>
                    }
                </div>
            </div>

            <div class="transport-group">
                <button class="btn-tap-tempo @(_tapFlash ? "flash" : "")" @onclick="HandleTapTempo">TAP<br/>TEMPO</button>
                @if (!_isPlaying)
                {
                    <button class="btn-action play-btn" @onclick="StartSequencerAsync">PLAY</button>
                }
                else
                {
                    <button class="btn-action stop-btn" @onclick="StopSequencerAsync">STOP</button>
                }
            </div>
        </div>
    </div>

    <!-- ── 5x16 LED Matrix Visualizer (Read Only) ───────────────────────── -->
    <div class="sequencer-card">
        <div class="sequencer-header">
            <h3>🎛️ ALGORITHMIC PATTERN MONITOR</h3>
            <span class="playhead-label">STEP: @((_currentStep + 1).ToString("D2")) / 16</span>
        </div>

        <div class="monitor-grid">
            @for (int trackIdx = 0; trackIdx < 5; trackIdx++)
            {
                int currentTrack = trackIdx;
                <div class="monitor-row">
                    <div class="track-info">
                        <span class="track-dot" style="background-color: @_trackColors[currentTrack]"></span>
                        <span class="track-name">@_trackNames[currentTrack]</span>
                    </div>
                    <div class="led-steps">
                        @for (int stepIdx = 0; stepIdx < 16; stepIdx++)
                        {
                            var currentStepIdx = stepIdx;
                            var isTriggered = _currentGrid[currentTrack][currentStepIdx];
                            var isPlayhead = currentStepIdx == _currentStep && _isPlaying;
                            
                            <div class="led-cell @(isTriggered ? "active" : "") @(isPlayhead ? "playhead" : "")"
                                 style="--track-color: @_trackColors[currentTrack]">
                                <div class="led-glow"></div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
