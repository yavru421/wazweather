    private StudioAudioState[] _presets = new StudioAudioState[4];
    private int _activePreset = 0;

    private bool _isPlaying = false;
    private int _currentStep = 0;

    private readonly string[] _trackNames = { "Kick", "Snare", "Hi-Hat", "Bass", "Melody" };
    private readonly string[] _trackColors = { "#ff3333", "#bd00ff", "#00d2ff", "#ffc837", "#00ff87" };

