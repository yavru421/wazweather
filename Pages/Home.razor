@page "/tuner"
@inject ITunerService TunerService
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Guitar & Instrument Tuner — TunerPWA</PageTitle>

<div class="tuner-page">

    <!-- ── Header ─────────────────────────────────────────── -->
    <div class="tuner-header">
        <div class="header-brand">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--signal)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18V5l12-2v13"/>
                <circle cx="6" cy="18" r="3"/>
                <circle cx="18" cy="16" r="3"/>
            </svg>
            <h1>TunerPWA</h1>
        </div>
        <div class="header-controls">
            <select id="preset-select" class="glass-select" @onchange="OnPresetChanged">
                @foreach (var preset in _presets)
                {
                    <option value="@_presets.IndexOf(preset)">@preset.Instrument — @preset.Name</option>
                }
            </select>
        </div>
    </div>

    <!-- ── Tuner Controls & View Toggle ────────────────────── -->
    <div class="view-selector-container">
        <button id="view-btn-cosmic" class="btn-view @(_currentView == TunerView.Cosmic ? "active" : "")" @onclick="() => SetView(TunerView.Cosmic)">Cosmic Ring</button>
        <button id="view-btn-laser" class="btn-view @(_currentView == TunerView.Laser ? "active" : "")" @onclick="() => SetView(TunerView.Laser)">Laser String</button>
        <button id="view-btn-strobe" class="btn-view @(_currentView == TunerView.Strobe ? "active" : "")" @onclick="() => SetView(TunerView.Strobe)">Strobe Wheel</button>
    </div>

    <!-- ── Tuner Visualizer ────────────────────────────────── -->
    <div class="tuner-dial-section">
        @if (_currentView == TunerView.Cosmic)
        {
            <div class="cosmic-tuner @TunerStateClass" style="--rms-scale: @(1.0 + _rms * 1.5)">
                <svg class="cosmic-svg" viewBox="0 0 300 300">
                    <defs>
                        <radialGradient id="glowGrad" cx="50%" cy="50%" r="50%">
                            <stop offset="0%" stop-color="var(--signal)" stop-opacity="0.3" />
                            <stop offset="100%" stop-color="var(--signal)" stop-opacity="0" />
                        </radialGradient>
                    </defs>
                    
                    <!-- Background gravity waves -->
                    <circle cx="150" cy="150" r="120" class="gravity-ring r-outer" />
                    <circle cx="150" cy="150" r="90" class="gravity-ring r-mid" />
                    <circle cx="150" cy="150" r="60" class="gravity-ring r-inner" />
                    
                    <!-- Pulsating audio glow -->
                    @if (_isListening && _rms > 0.01)
                    {
                        <circle cx="150" cy="150" r="@(60 + _rms * 120)" fill="url(#glowGrad)" />
                    }
                    
                    <!-- Orbital target line -->
                    <line x1="150" y1="30" x2="150" y2="270" class="target-axis" />
                    <line x1="30" y1="150" x2="270" y2="150" class="target-axis" />
                    
                    <!-- The satellite orbital node -->
                    <circle cx="@CosmicSatelliteX.ToString("F1")" cy="@CosmicSatelliteY.ToString("F1")" r="12" class="satellite-node @TunerStateClass" />
                    
                    <!-- Center Core -->
                    <circle cx="150" cy="150" r="40" class="core-planet @TunerStateClass" />
                    <text x="150" y="158" class="core-text">@_currentNote</text>
                </svg>
            </div>
        }
        else if (_currentView == TunerView.Laser)
        {
            <div class="laser-tuner @TunerStateClass">
                <svg class="laser-svg" viewBox="0 0 300 180">
                    <!-- Laser lock grid lines -->
                    <line x1="150" y1="10" x2="150" y2="170" class="laser-centerline" />
                    <line x1="75" y1="10" x2="75" y2="170" class="laser-guideline" opacity="0.15" />
                    <line x1="225" y1="10" x2="225" y2="170" class="laser-guideline" opacity="0.15" />
                    
                    <!-- Vibrating string curve -->
                    <path d="@GetLaserStringPath()" class="laser-string @TunerStateClass" />
                    
                    <!-- Laser cursor node representing exact pitch location -->
                    @if (_isListening && _currentNote != "--")
                    {
                        <circle cx="@LaserCursorX.ToString("F1")" cy="@LaserCursorY.ToString("F1")" r="8" class="laser-cursor @TunerStateClass" />
                        <line x1="@LaserCursorX.ToString("F1")" y1="@LaserCursorY.ToString("F1")" x2="@LaserCursorX.ToString("F1")" y2="170" class="laser-cursor-guide @TunerStateClass" stroke-dasharray="3 3" />
                    }
                </svg>
                <div class="laser-reading @TunerStateClass">
                    <span class="laser-note">@_currentNote</span>
                    <span class="laser-cents">@(_cents > 0 ? $"+{_cents}" : _cents.ToString()) cents</span>
                </div>
            </div>
        }
        else
        {
            <div class="strobe-tuner @TunerStateClass">
                <div class="strobe-wheel-container">
                    <div class="strobe-wheel @StrobeDirectionClass" style="@StrobeSpeedStyle">
                        <!-- Render rotation markers -->
                        <svg class="strobe-svg" viewBox="0 0 200 200">
                            <circle cx="100" cy="100" r="90" class="strobe-track" fill="none" stroke-width="6" />
                            @for (int i = 0; i < 24; i++)
                            {
                                var angle = i * (360.0 / 24.0);
                                <line x1="100" y1="10" x2="100" y2="20" class="strobe-marker" transform="rotate(@angle 100 100)" />
                            }
                            <circle cx="100" cy="100" r="70" class="strobe-track-inner" fill="none" stroke-width="4" />
                            @for (int i = 0; i < 16; i++)
                            {
                                var angle = (i * (360.0 / 16.0)) + 11.25;
                                <line x1="100" y1="30" x2="100" y2="38" class="strobe-marker" transform="rotate(@angle 100 100)" />
                            }
                        </svg>
                    </div>
                    <!-- Core pitch indicator in the center of the wheel -->
                    <div class="strobe-core @TunerStateClass">
                        <span class="strobe-note">@_currentNote</span>
                        <span class="strobe-cents">@(_cents > 0 ? $"+{_cents}" : _cents.ToString())</span>
                    </div>
                </div>
            </div>
        }

        <!-- ── Common Cents Display ────────────────────────── -->
        @if (_currentView != TunerView.Laser && _currentView != TunerView.Strobe)
        {
            <div class="cents-display">
                <span class="cents-value @(Math.Abs(_cents) > 50 ? "cents-extreme" : "")">
                    @(_cents > 0 ? $"+{_cents}" : _cents.ToString())
                </span>
                <span class="cents-label">cents</span>
            </div>
        }

        <!-- ── Note Display ─────────────────────────────────── -->
        <div class="note-display @TunerStateClass">
            <span class="detected-note">@_currentNote</span>
            @if (_currentOctave > 0)
            {
                <span class="detected-octave">@_currentOctave</span>
            }
            <div class="tune-status-badge @TunerStateClass">
                @TuneStatusText
            </div>
        </div>

        <!-- ── Frequency readout ─────────────────────────────── -->
        @if (_currentFrequency > 0)
        {
            <div class="freq-display">
                <span class="freq-value">@_currentFrequency.ToString("F1")</span>
                <span class="freq-unit">Hz</span>
                @if (_targetFrequency > 0)
                {
                    <span class="freq-target">→ @_targetFrequency.ToString("F1") Hz</span>
                }
            </div>
        }
    </div>

    <!-- ── Instrument Strings ─────────────────────────────── -->
    @if (_activePreset != null)
    {
        <div class="strings-section">
            <div class="strings-label">@_activePreset.Instrument — @_activePreset.Name</div>
            <div class="strings-grid">
                @foreach (var str in _activePreset.Strings)
                {
                    var isTarget = IsStringTarget(str);
                    var isActive = isTarget && _isListening;
                    <button id="string-btn-@str.Name" class="string-card @(isActive ? "string-active" : "") @(isTarget ? "string-target" : "")"
                            @onclick="() => PlayStringTone(str)">
                        <span class="string-number">@str.Name</span>
                        <span class="string-note">@str.Note<sub>@str.Octave</sub></span>
                        <span class="string-freq">@str.Frequency.ToString("F1") Hz</span>
                    </button>
                }
            </div>
        </div>
    }

    <!-- ── Controls ───────────────────────────────────────── -->
    <div class="tuner-controls">
        @if (!_isListening)
        {
            <button id="btn-start-tuner" class="btn-tuner-primary" @onclick="StartTunerAsync" disabled="@_isStarting">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" y1="19" x2="12" y2="23"/>
                    <line x1="8" y1="23" x2="16" y2="23"/>
                </svg>
                @(_isStarting ? "Starting..." : "Start Tuner")
            </button>
        }
        else
        {
            <button id="btn-stop-tuner" class="btn-tuner-stop" @onclick="StopTunerAsync">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                </svg>
                Stop Tuner
            </button>
        }
        @if (_isTonePlaying)
        {
            <button id="btn-stop-tone" class="btn-tuner-secondary" @onclick="StopToneAsync">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
                Stop Tone
            </button>
        }
    </div>

    <!-- ── A4 Calibration ─────────────────────────────────── -->
    <div class="calibration-row">
        <label class="calib-label">A4 Reference</label>
        <input id="a4-slider" type="range" min="430" max="450" step="1" class="glass-slider"
               @bind="_a4Reference" @bind:event="oninput" @onchange="OnA4Changed"/>
        <span class="calib-value">@_a4Reference Hz</span>
        <button class="btn-calib-reset" @onclick="ResetA4">Reset</button>
    </div>

</div>

@code {
    private bool _isSupported = true;
    private bool _isListening = false;
    private bool _isStarting = false;
    private bool _isTonePlaying = false;

    // Current reading
    private string _currentNote = "--";
    private int _currentOctave = 0;
    private int _cents = 0;
    private double _currentFrequency = -1;
    private double _targetFrequency = 0;
    private double _rms = 0;

    // Calibration
    private int _a4Reference = 440;

    // Presets
    private List<TuningPreset> _presets = new();
    private TuningPreset? _activePreset;
    private int _activePresetIndex = 0;

    // JS interop
    private DotNetObjectReference<object>? _selfRef;

    private enum TunerView
    {
        Cosmic,
        Laser,
        Strobe
    }

    private TunerView _currentView = TunerView.Cosmic;
    private void SetView(TunerView view) => _currentView = view;

    // ── Cosmic View Calculation ──────────────────────────────
    private double CosmicSatelliteAngleRad => (_cents / 50.0) * (Math.PI * 0.75) - (Math.PI / 2.0); // angle centered at -90deg (top)
    private double CosmicSatelliteX => 150 + 105 * Math.Cos(CosmicSatelliteAngleRad);
    private double CosmicSatelliteY => 150 + 105 * Math.Sin(CosmicSatelliteAngleRad);

    // ── Laser View Calculation ───────────────────────────────
    private double LaserCursorX => 150 + (_cents / 50.0) * 120.0; // range 30 to 270
    private double LaserCursorY => 90 - (Math.Sin((LaserCursorX - 20) / 260.0 * Math.PI) * Math.Min(25, _rms * 250.0));

    private string GetLaserStringPath()
    {
        if (!_isListening || _rms < 0.005)
            return "M 20 90 L 280 90";

        double amp = Math.Min(25, _rms * 250.0);
        // String curves dynamically based on vibration and frequency alignment
        return $"M 20 90 Q 150 {90 - amp} 280 90";
    }

    // ── Strobe View Calculation ──────────────────────────────
    private string StrobeDirectionClass => Math.Abs(_cents) <= 2 ? "strobe-locked" : (_cents > 0 ? "strobe-clockwise" : "strobe-counter");
    private string StrobeSpeedStyle
    {
        get
        {
            if (Math.Abs(_cents) <= 2)
                return "animation-duration: 0s; animation-play-state: paused;";
            double duration = Math.Max(0.2, 8.0 / Math.Abs(_cents));
            return $"animation-duration: {duration.ToString("F2")}s;";
        }
    }

    private string TunerStateClass
    {
        get
        {
            if (!_isListening || _currentNote == "--") return "";
            if (Math.Abs(_cents) <= 5) return "state-in-tune";
            if (Math.Abs(_cents) <= 15) return "state-close";
            return Math.Sign(_cents) < 0 ? "state-flat" : "state-sharp";
        }
    }

    private string TuneStatusText
    {
        get
        {
            if (!_isListening) return "Start tuner";
            if (_currentNote == "--") return "Listening...";
            if (Math.Abs(_cents) <= 5) return "✓ In Tune";
            if (Math.Abs(_cents) <= 15) return "Almost there";
            return _cents < 0 ? "▲ Too Flat" : "▼ Too Sharp";
        }
    }

    private bool IsStringTarget(InstrumentString s)
    {
        return _currentNote == s.Note && Math.Abs(_currentOctave - s.Octave) <= 1
               && Math.Abs(_cents) <= 30;
    }

    protected override void OnInitialized()
    {
        _presets = TunerService.GetPresets().ToList();
        _activePreset = _presets.FirstOrDefault();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isSupported = await TunerService.IsSupportedAsync();
            StateHasChanged();
        }
    }

    private async Task StartTunerAsync()
    {
        _isStarting = true;
        StateHasChanged();
        await Task.Delay(50);
        try
        {
            _selfRef = DotNetObjectReference.Create<object>(this);
            var ok = await TunerService.StartTunerAsync(_selfRef, nameof(OnTunerReading));
            if (ok)
            {
                _isListening = true;
                ToastService.Success("Tuner active — play a note!");
            }
            else
            {
                ToastService.Error("Microphone access denied.");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error($"Failed to start: {ex.Message}");
        }
        _isStarting = false;
        StateHasChanged();
    }

    private async Task StopTunerAsync()
    {
        await TunerService.StopTunerAsync();
        _isListening = false;
        _currentNote = "--";
        _currentOctave = 0;
        _cents = 0;
        _currentFrequency = -1;
        _targetFrequency = 0;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnTunerReading(System.Text.Json.JsonElement data)
    {
        double nextFreq = data.GetProperty("frequency").GetDouble();
        string nextNote = data.GetProperty("note").GetString() ?? "--";
        int nextOctave = data.GetProperty("octave").GetInt32();
        int nextCents = data.GetProperty("cents").GetInt32();
        double nextRms = data.GetProperty("rms").GetDouble();

        if (nextNote == "--" || _currentNote == "--" || nextNote != _currentNote || nextOctave != _currentOctave)
        {
            // Reset and jump immediately if the note name changes or falls silent
            _currentNote = nextNote;
            _currentOctave = nextOctave;
            _cents = nextCents;
            _currentFrequency = nextFreq;
        }
        else
        {
            // Exponential Moving Average (EMA) smoothing for cents and frequency to prevent rapid jittering
            const double alpha = 0.25; // Smoothing factor (0.0 to 1.0) where lower is smoother
            _cents = (int)Math.Round(_cents * (1.0 - alpha) + nextCents * alpha);
            _currentFrequency = _currentFrequency * (1.0 - alpha) + nextFreq * alpha;
        }

        _rms = nextRms;

        if (data.TryGetProperty("targetFrequency", out var tf))
            _targetFrequency = tf.GetDouble();

        StateHasChanged();
    }

    private async Task PlayStringTone(InstrumentString str)
    {
        _isTonePlaying = true;
        StateHasChanged();
        await TunerService.PlayToneAsync(str.Frequency, "sine");
    }

    private async Task StopToneAsync()
    {
        await TunerService.StopToneAsync();
        _isTonePlaying = false;
        StateHasChanged();
    }

    private void OnPresetChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx))
        {
            _activePresetIndex = idx;
            _activePreset = _presets[idx];
        }
    }

    private void OnA4Changed(ChangeEventArgs e) => StateHasChanged();
    private void ResetA4() { _a4Reference = 440; StateHasChanged(); }

    public async ValueTask DisposeAsync()
    {
        if (_isListening) await StopTunerAsync();
        if (_isTonePlaying) await StopToneAsync();
        _selfRef?.Dispose();
    }
}
