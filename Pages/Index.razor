@page "/"
@inject NavigationManager Navigation

<div class="home-screen">
    <div class="brand-title">ShotStack<span class="accent">.</span></div>
    <div class="brand-subtitle">Portfolio Assembly Desk</div>
    
    <button class="fab-new-doc" @onclick="GoToEditor">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        New Document
    </button>
    
    <div class="branding-footer">
        another bleeding-edge application from DondlingerGC.com
    </div>
</div>

@code {
    private void GoToEditor()
    {
        Navigation.NavigateTo("/editor");
    }
}
