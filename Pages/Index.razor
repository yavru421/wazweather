@page "/"
@using System.Runtime.InteropServices.JavaScript
@implements IDisposable

<div class="glass-pane-container">
    <!-- Layer 0: The Video Feed -->
    <video id="cameraFeed" class="glass-pane-video" playsinline autoplay muted></video>
    
    <!-- Layer 1: The Canvas Overlay -->
    <canvas id="measureCanvas" class="glass-pane-canvas"></canvas>

    <!-- Layer 2: The UI Controls -->
    <div class="glass-pane-ui">
        <div class="ui-panel">
            <div class="measurement-display">
                <span class="value">@LatestMeasurement.ToString("F1")</span>
                <span class="unit">mm</span>
            </div>
            <div class="mode-indicator" style="color: #ccc; font-size: 0.9rem; margin-bottom: 8px;">
                Mode: <strong>@CurrentMode</strong>
            </div>
            
            <div class="button-group">
                <button class="btn @(CurrentMode == "Calibrate" ? "btn-primary" : "btn-secondary")" @onclick="SetCalibrateMode">Calibrate</button>
                <button class="btn @(CurrentMode == "Measure" ? "btn-primary" : "btn-secondary")" @onclick="SetMeasureMode">Measure</button>
            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize the canvas and touch listeners from the JS module
            await InitializeJavaScriptAsync();
        }
    }

    [JSImport("initCanvas", "ruler")]
    internal static partial void InitCanvasInterop();

    [JSImport("bindInterop", "ruler")]
    internal static partial void BindInterop();

    private async Task InitializeJavaScriptAsync()
    {
        // Import our ruler.js module dynamically 
        await JSHost.ImportAsync("ruler", "../js/ruler.js");
        
        // Initialize the canvas resize and touch event listeners
        InitCanvasInterop();
    }
}
