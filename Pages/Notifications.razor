@page "/notifications"
@inject HttpClient Http

<PageTitle>Notifications</PageTitle>

<div class="container mx-auto p-4 max-w-lg">
    <h1 class="text-3xl font-bold mb-6 text-gray-800 dark:text-gray-100">Latest Alerts</h1>

    @if (_loading)
    {
        <div class="flex justify-center p-8">
            <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-blue-500"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
            <strong class="font-bold">Error!</strong>
            <span class="block sm:inline"> @_error</span>
        </div>
    }
    else if (_notification != null)
    {
        <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6 border-l-4 border-blue-500">
            <div class="flex items-center justify-between mb-2">
                <h2 class="text-xl font-semibold text-gray-900 dark:text-white">@_notification.Title</h2>
                @if (_notification.Timestamp > 0)
                {
                    <span class="text-xs text-gray-500 dark:text-gray-400">
                        @DateTimeOffset.FromUnixTimeMilliseconds(_notification.Timestamp).ToLocalTime().ToString("g")
                    </span>
                }
            </div>
            
            <p class="text-gray-700 dark:text-gray-300 mb-4 whitespace-pre-wrap">@_notification.Body</p>
            
            @if (!string.IsNullOrEmpty(_notification.Link))
            {
                <a href="@_notification.Link" target="_blank" rel="noopener noreferrer" 
                   class="inline-block bg-blue-500 hover:bg-blue-600 text-white font-medium py-2 px-4 rounded transition-colors">
                    View Details
                </a>
            }
        </div>
    }
    else
    {
        <div class="bg-gray-100 dark:bg-gray-700 rounded-lg p-6 text-center text-gray-500 dark:text-gray-400">
            No recent notifications found.
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private NotificationModel? _notification;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loading = true;
            _notification = await Http.GetFromJsonAsync<NotificationModel>("/api/latest-notification");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    public class NotificationModel
    {
        public string Title { get; set; } = string.Empty;
        public string Body { get; set; } = string.Empty;
        public string? Link { get; set; }
        public long Timestamp { get; set; }
    }
}
