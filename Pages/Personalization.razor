@page "/personalization"
@using System.Net.Http.Json
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@inject NavigationManager NavigationManager

<div class="pers-container">
    <div class="pers-header">
        <button class="pers-close-btn" @onclick="CloseModal" aria-label="Close">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <h1 class="pers-title">Settings</h1>
        <p class="pers-subtitle">Customize your Zero-Liability weather experience.</p>
    </div>

    @if (isLoading)
    {
        <div class="pers-loading">
            <div class="pers-spinner"></div>
            <p>Loading Preferences...</p>
        </div>
    }
    else
    {
        <div class="pers-form">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="pers-error">@errorMessage</div>
            }
            @if (showSuccess)
            {
                <div class="pers-success">Preferences Saved Successfully!</div>
            }

            <div class="pers-tabs">
                <button class="pers-tab-btn @(currentTab == "personalization" ? "active" : "")" @onclick='() => SwitchTab("personalization")'>Preferences</button>
                <button class="pers-tab-btn @(currentTab == "notifications" ? "active" : "")" @onclick='() => SwitchTab("notifications")'>Alerts & Push</button>
            </div>

            @if (currentTab == "personalization")
            {
                <div class="pers-group">
                    <label class="pers-label">Unique Username</label>
                    <input class="pers-input" type="text" @bind="username" placeholder="e.g. stormchaser99" maxlength="30" />
                    <p class="pers-help">Choose a unique handle for community features.</p>
                </div>

                <div class="pers-group">
                    <label class="pers-label">Default Zip Code</label>
                    <input class="pers-input" type="text" @bind="defaultZip" placeholder="e.g. 54494" maxlength="10" />
                </div>

                <div class="pers-group">
                    <label class="pers-label">Temperature Units</label>
                    <div class="pers-toggle">
                        <button class="pers-toggle-btn @(tempUnits == "F" ? "active" : "")" @onclick='() => tempUnits = "F"'>°F</button>
                        <button class="pers-toggle-btn @(tempUnits == "C" ? "active" : "")" @onclick='() => tempUnits = "C"'>°C</button>
                    </div>
                </div>

                <div class="pers-group">
                    <label class="pers-label">Theme Preference</label>
                    <div class="pers-select-wrap">
                        <select class="pers-select" @bind="themePreference">
                            <option value="Dark">Obsidian Dark (Default)</option>
                            <option value="Light">Glacier Light</option>
                            <option value="OLED">OLED Pure Black</option>
                        </select>
                    </div>
                </div>

                <button class="pers-save-btn" @onclick="SavePreferences" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span>Saving...</span>
                    }
                    else
                    {
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        <span>Save Preferences</span>
                    }
                </button>
            }
            else if (currentTab == "notifications")
            {
                <div class="pers-group">
                    <label class="pers-label">Latest Broadcast Alert</label>
                    @if (_loadingNotification)
                    {
                        <div class="pers-loading" style="padding: 20px 0;">
                            <div class="pers-spinner" style="width:30px; height:30px; margin-bottom:8px;"></div>
                            <p style="font-size:0.95rem;">Checking Broadcast Stream...</p>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(_notificationError))
                    {
                        <div class="pers-error">@_notificationError</div>
                    }
                    else if (_notification != null)
                    {
                        <div class="alert-card">
                            <div class="alert-card-title">@_notification.Title</div>
                            <div class="alert-card-body">@_notification.Body</div>
                            @if (_notification.Timestamp > 0)
                            {
                                <span class="alert-card-time">
                                    @DateTimeOffset.FromUnixTimeMilliseconds(_notification.Timestamp).ToLocalTime().ToString("g")
                                </span>
                            }
                        </div>
                    }
                    else
                    {
                        <p style="color:#98989d; font-size:1rem; text-align:center; padding: 10px 0;">No active broadcast alerts.</p>
                    }
                </div>

                <div class="pers-group">
                    <label class="pers-label">Push Notification Subscriptions</label>
                    <p style="color: #98989d; font-size: 0.9rem; margin-bottom: 20px; line-height: 1.4;">
                        Receive real-time alerts for severe weather warnings, critical hydrology discharge levels, and local air quality.
                    </p>
                    
                    <div class="pers-checkbox-group" style="margin-bottom: 24px;">
                        <label class="pers-checkbox-label">
                            <input type="checkbox" id="pref-weather-alerts" class="pers-checkbox" checked />
                            <span>Severe Weather Warnings</span>
                        </label>
                        <label class="pers-checkbox-label">
                            <input type="checkbox" id="pref-river-alerts" class="pers-checkbox" checked />
                            <span>Hydrology & Flow Alerts</span>
                        </label>
                        <label class="pers-checkbox-label">
                            <input type="checkbox" id="pref-aqi-alerts" class="pers-checkbox" checked />
                            <span>Air Quality Alerts</span>
                        </label>
                    </div>

                    <button id="btn-weather-push" @onclick="TogglePush" class="pers-save-btn" style="width: 100%; text-transform: uppercase;">
                        Enable Weather Alerts
                    </button>
                    <div id="weather-push-status" style="text-align: center; font-size: 0.85rem; color: #98989d; margin-top: 12px; line-height: 1.4;"></div>
                </div>
            }
        </div>
    }
</div>

@code {
    private string uuid = "";
    private string username = "";
    private string defaultZip = "";
    private string tempUnits = "F";
    private string themePreference = "Dark";
    
    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = "";
    private bool showSuccess = false;

    private string currentTab = "personalization";
    private bool _loadingNotification = true;
    private string? _notificationError;
    private NotificationModel? _notification;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            uuid = await JSRuntime.InvokeAsync<string>("wazGetLocalStorage", "waz_user_uuid");
            if (string.IsNullOrEmpty(uuid))
            {
                uuid = Guid.NewGuid().ToString();
                await JSRuntime.InvokeVoidAsync("wazSetLocalStorage", "waz_user_uuid", uuid);
            }

            var response = await Http.GetAsync($"/api/preferences?uuid={uuid}");
            if (response.IsSuccessStatusCode)
            {
                var prefs = await response.Content.ReadFromJsonAsync<UserPreferences>();
                if (prefs != null)
                {
                    username = prefs.username ?? "";
                    defaultZip = prefs.default_zip ?? "";
                    tempUnits = prefs.temp_units ?? "F";
                    themePreference = prefs.theme_preference ?? "Dark";
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading preferences: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SwitchTab(string tab)
    {
        currentTab = tab;
        if (currentTab == "notifications")
        {
            await LoadLatestNotification();
            // Give Blazor time to render the checkbox DOM elements before init push
            await Task.Delay(50);
            await JSRuntime.InvokeVoidAsync("initWeatherPush");
        }
    }

    private async Task LoadLatestNotification()
    {
        try
        {
            _loadingNotification = true;
            _notification = await Http.GetFromJsonAsync<NotificationModel>("/api/latest-notification");
        }
        catch (Exception ex)
        {
            _notificationError = ex.Message;
        }
        finally
        {
            _loadingNotification = false;
        }
    }

    private async Task TogglePush()
    {
        await JSRuntime.InvokeVoidAsync("toggleWeatherPush");
    }

    private async Task SavePreferences()
    {
        isSaving = true;
        errorMessage = "";
        showSuccess = false;
        StateHasChanged();

        try
        {
            var payload = new UserPreferences
            {
                user_uuid = uuid,
                username = string.IsNullOrWhiteSpace(username) ? null : username.Trim(),
                default_zip = defaultZip,
                temp_units = tempUnits,
                theme_preference = themePreference
            };

            var response = await Http.PostAsJsonAsync("/api/preferences", payload);
            
            if (response.IsSuccessStatusCode)
            {
                showSuccess = true;
                // Optional: apply theme changes via JS Interop immediately
                if (themePreference == "OLED")
                {
                    await JSRuntime.InvokeVoidAsync("document.body.style.setProperty", "background-color", "#000000");
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("document.body.style.setProperty", "background-color", "#12141c");
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                errorMessage = "Username is already taken. Please choose another.";
            }
            else
            {
                var errorResult = await response.Content.ReadAsStringAsync();
                errorMessage = "Failed to save: " + errorResult;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while saving.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
            
            if (showSuccess)
            {
                await Task.Delay(3000);
                showSuccess = false;
                StateHasChanged();
            }
        }
    }

    private async Task CloseModal()
    {
        await JSRuntime.InvokeVoidAsync("closePersonalization");
    }

    public class UserPreferences
    {
        public string? user_uuid { get; set; }
        public string? username { get; set; }
        public string? default_zip { get; set; }
        public string? temp_units { get; set; }
        public string? theme_preference { get; set; }
    }

    public class NotificationModel
    {
        public string Title { get; set; } = string.Empty;
        public string Body { get; set; } = string.Empty;
        public string? Link { get; set; }
        public long Timestamp { get; set; }
    }
}
