@inject IPwaInstallService PwaInstall
@inject IJSRuntime JSRuntime
@implements IDisposable

@if (_shouldRender)
{
    <div class="pwa-install-container @(Class ?? "")">
        <button class="pwa-install-button" @onclick="HandleInstallClickAsync" title="Install ShotStack Studio to your device">
            <svg class="install-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            <span>Install App</span>
        </button>

        @if (_showIosTooltip)
        {
            <div class="pwa-ios-tooltip-backdrop" @onclick="CloseIosTooltip"></div>
            <div class="pwa-ios-tooltip">
                <div class="tooltip-header">
                    <strong>Install on iOS</strong>
                    <button class="tooltip-close" @onclick="CloseIosTooltip">×</button>
                </div>
                <div class="tooltip-body">
                    <p>To install <strong>ShotStack Studio</strong> on your iOS device:</p>
                    <ol>
                        <li>Tap the <strong>Share</strong> button <svg class="inline-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg> in Safari.</li>
                        <li>Scroll down and tap <strong>Add to Home Screen</strong> <svg class="inline-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>.</li>
                        <li>Tap <strong>Add</strong> in the top-right corner.</li>
                    </ol>
                </div>
                <div class="tooltip-arrow"></div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public string? Class { get; set; }

    private bool _isStandalone = false;
    private bool _isIos = false;
    private bool _showIosTooltip = false;
    private IJSObjectReference? _pwaModule;

    private bool _shouldRender => !_isStandalone && (PwaInstall.IsInstallable || _isIos);

    protected override void OnInitialized()
    {
        PwaInstall.OnInstallableChanged += HandleInstallableChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _pwaModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/pwa.module.js");
                _isStandalone = await _pwaModule.InvokeAsync<bool>("isStandalone");
                _isIos = await _pwaModule.InvokeAsync<bool>("isIos");
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"[PwaInstallButton] Error during module import or check: {ex.Message}");
            }
        }
    }

    private void HandleInstallableChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleInstallClickAsync()
    {
        if (_isIos)
        {
            _showIosTooltip = true;
        }
        else if (PwaInstall.IsInstallable)
        {
            await PwaInstall.PromptInstallAsync();
        }
    }

    private void CloseIosTooltip()
    {
        _showIosTooltip = false;
    }

    public void Dispose()
    {
        PwaInstall.OnInstallableChanged -= HandleInstallableChanged;
    }
}
